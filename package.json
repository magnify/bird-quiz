    "next": "16.1.6",
    "next-intl": "^4.13.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-image-crop": "^11.0.10",
    "recharts": "^3.8.1",
    "shadcn": "^4.0.0",
